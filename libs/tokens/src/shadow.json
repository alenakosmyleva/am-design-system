{
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": [
        {
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "12px",
          "spread": "0px",
          "color": "{colors.effects.secondary}"
        },
        {
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "1px",
          "spread": "0px",
          "color": "{colors.effects.tertiary}"
        }
      ]
    },
    "md": {
      "$type": "shadow",
      "$value": [
        {
          "offsetX": "0px",
          "offsetY": "8px",
          "blur": "24px",
          "spread": "0px",
          "color": "{colors.effects.primary}"
        },
        {
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "4px",
          "spread": "0px",
          "color": "{colors.effects.secondary}"
        }
      ]
    },
    "lg": {
      "$type": "shadow",
      "$value": [
        {
          "offsetX": "0px",
          "offsetY": "20px",
          "blur": "64px",
          "spread": "0px",
          "color": "{colors.effects.primary}"
        },
        {
          "offsetX": "0px",
          "offsetY": "2px",
          "blur": "12px",
          "spread": "0px",
          "color": "{colors.effects.secondary}"
        }
      ]
    }
  }
}
